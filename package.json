{
  "name": "robotmoney-skills",
  "version": "0.1.0",
  "private": true,
  "description": "Robot Money skills and CLI for AI agents and autonomous machines",
  "repository": {
    "type": "git",
    "url": "https://github.com/robotmoney/robotmoney-skills"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "test": "pnpm -r --filter \"./packages/*\" test",
