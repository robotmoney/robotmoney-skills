    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@open-wallet-standard/core": "1.2.4",
    "@uniswap/sdk-core": "^7.13.0",
    "@uniswap/universal-router-sdk": "^5.1.0",
    "@uniswap/v3-sdk": "^3.30.0",
    "@uniswap/v4-sdk": "^2.0.0",
    "commander": "^12.0.0",
    "viem": "^2.21.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
