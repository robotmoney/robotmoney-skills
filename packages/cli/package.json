{
  "name": "@robotmoney/cli",
  "version": "0.2.1",
  "description": "CLI for the Robot Money stablecoin yield vault on Base — for AI agents and autonomous machines",
  "keywords": [
    "robotmoney",
    "defi",
    "usdc",
    "yield",
    "vault",
    "erc4626",
    "ai-agents",
    "machines",
    "base"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robotmoney/robotmoney-skills",
    "directory": "packages/cli"
  },
  "homepage": "https://robotmoney.net",
  "type": "module",
  "bin": {
    "robotmoney": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
